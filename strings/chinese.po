#. STRINGS.UI.SANDBOXMENU.ADVENTURECHAPTER
#, lua-format
msgctxt "STRINGS.UI.SANDBOXMENU.ADVENTURECHAPTER"
msgid "Chapter %d of %d"
msgstr "第%d/%d章"

#. STRINGS.UI.WORLDRESETDIALOG.REGEN_MSG_ADVENTURE
#, lua-format
msgctxt "STRINGS.UI.WORLDRESETDIALOG.REGEN_MSG_ADVENTURE"
msgid "Everyone is dead. Everyone will return to the main world in: %d"
msgstr "每个人都死了。所有人即将返回：%d"

#. STRINGS.UI.WORLDRESETDIALOG.RESET_BUTTON_ADVENTURE
#, lua-format
msgctxt "STRINGS.UI.WORLDRESETDIALOG.RESET_BUTTON_ADVENTURE"
msgid "Return Now"
msgstr "现在返回"

#. STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_TITLE
msgctxt "STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_TITLE"
msgid "Return to the Original World"
msgstr "开始返回世界"

#. STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_BODY
msgctxt "STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_BODY"
msgid "Are you sure you want to return to the original world?"
msgstr "确定要返回到原来的世界吗？"

#. STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_NEXT_CHAPTER_CONFIRM_TITLE
msgctxt "STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_NEXT_CHAPTER_CONFIRM_TITLE"
msgid "The current world will be destroyed, begin the next Adventure Mode chapter? Every living player must confirm activation."
msgstr "当前世界即将毁灭，是否开启下一章节？所有存活玩家必须确认激活。"