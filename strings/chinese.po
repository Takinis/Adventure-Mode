#. STRINGS.UI.SANDBOXMENU.ADVENTURECHAPTER
#, lua-format
msgctxt "STRINGS.UI.SANDBOXMENU.ADVENTURECHAPTER"
msgid "Chapter %d of %d"
msgstr "第%d/%d章"

#. STRINGS.UI.WORLDRESETDIALOG.REGEN_MSG_ADVENTURE
#, lua-format
msgctxt "STRINGS.UI.WORLDRESETDIALOG.REGEN_MSG_ADVENTURE"
msgid "Everyone is dead. Everyone will return to the main world in: %d"
msgstr "每个人都死了。所有人即将返回：%d"

#. STRINGS.UI.WORLDRESETDIALOG.RESET_BUTTON_ADVENTURE
#, lua-format
msgctxt "STRINGS.UI.WORLDRESETDIALOG.RESET_BUTTON_ADVENTURE"
msgid "Return Now"
msgstr "现在返回"

#. STRINGS.UI.HUD.TELEPORTATO_PLAYER_CONFIRMED
#, lua-format
msgctxt "STRINGS.UI.HUD.TELEPORTATO_PLAYER_CONFIRMED"
msgid "Player %s has confirmed."
msgstr "玩家 %s 已确认"

#. STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_TITLE
msgctxt "STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_TITLE"
msgid "Return to the Original World"
msgstr "开始返回世界"

#. STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_BODY
msgctxt "STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_RETURN_CONFIRM_BODY"
msgid "Are you sure you want to return to the original world?"
msgstr "确定要返回到原来的世界吗？"

#. STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_NEXT_CHAPTER_CONFIRM_TITLE
msgctxt "STRINGS.UI.WORLDRESETDIALOG.ADVENTURE_NEXT_CHAPTER_CONFIRM_TITLE"
msgid "The current world will be destroyed, begin the next Adventure Mode chapter? Every living player must confirm activation."
msgstr "当前世界即将毁灭，是否开启下一章节？所有存活玩家必须确认激活。"

#. STRINGS.UI.ENDGAME.BODY1
msgctxt "STRINGS.UI.ENDGAME.BODY1"
msgid "And so the cycle continues. Will "
msgstr "于是轮回又将开始。"

#. STRINGS.UI.ENDGAME.BODY2
#, lua-format
msgctxt "STRINGS.UI.ENDGAME.BODY2"
msgid " ever escape?\n Perhaps %s too will tire of this wretched place, and use %s new powers to tempt the unsuspecting.\n\nThe mysterious beings that control this place still lurk in the shadows, and new challenges will soon be revealed.\n\n\nUntil then,\n- The Don't Starve Team -"
msgstr "能够逃脱吗？\n或许%s也会对这个不幸的地方感到厌倦，并运用%s新力量来诱惑不知情的人上钩。\n\n掌控此地的神秘生物仍潜伏在阴影中，新的挑战即将揭晓。\n\n\n直到那时，\n-《饥荒》团队 -"

#. STRINGS.UI.ENDGAME.TITLE
msgctxt "STRINGS.UI.ENDGAME.TITLE"
msgid "The End."
msgstr "剧终。"

#. STRINGS.UI.ENDGAME.YES
msgctxt "STRINGS.UI.ENDGAME.YES"
msgid "For Science!"
msgstr "为了科学！"

#. STRINGS.UI.GENDERSTRINGS.FEMALE.ONE
msgctxt "STRINGS.UI.GENDERSTRINGS.FEMALE.ONE"
msgid "she"
msgstr "她"

#. STRINGS.UI.GENDERSTRINGS.FEMALE.TWO
msgctxt "STRINGS.UI.GENDERSTRINGS.FEMALE.TWO"
msgid "her"
msgstr "她的"

#. STRINGS.UI.GENDERSTRINGS.MALE.ONE
msgctxt "STRINGS.UI.GENDERSTRINGS.MALE.ONE"
msgid "he"
msgstr "他"

#. STRINGS.UI.GENDERSTRINGS.MALE.TWO
msgctxt "STRINGS.UI.GENDERSTRINGS.MALE.TWO"
msgid "his"
msgstr "他的"

#. STRINGS.UI.GENDERSTRINGS.ROBOT.ONE
msgctxt "STRINGS.UI.GENDERSTRINGS.ROBOT.ONE"
msgid "they"
msgstr "它"

#. STRINGS.UI.GENDERSTRINGS.ROBOT.TWO
msgctxt "STRINGS.UI.GENDERSTRINGS.ROBOT.TWO"
msgid "their"
msgstr "他们的"
